# 2) TODO — load the function definition WITHOUT triggering its self-invoke line.
#    Strip the trailing invocation, then eval just the class/module definition.
FUNCTION_FILE = File.expand_path(
  "../../iprod/functions/csd_demo/workcenter_shift_statistics.rb", __dir__
)

def load_function_class!
  src = File.read(FUNCTION_FILE)
  # Drop the final top-level invocation line(s) (e.g. `Klass.new(...).main(args)`).
  # Adjust this filter to match your file's tail.
  body = src.lines.reject { |ln| ln =~ /\.new\(.*\)\.main\(|\)\.main\(args\)|^\w[\w:]*\(current_license_key/ }.join
  eval(body, TOPLEVEL_BINDING, FUNCTION_FILE) # rubocop:disable Security/Eval
end

load_function_class! unless defined?(@function_loaded)
@function_loaded = true

