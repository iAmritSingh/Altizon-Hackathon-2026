# Copy this to drivers/<your_function>_driver.rb and fill in the three TODOs.
# Then run, e.g.:
#   ruby load_test.rb --driver drivers/<your_function>_driver.rb -c 8 -n 500
#
# Why a driver and not "just point at the .rb"? MInt function files end with a
# self-invoking line like:
#     MyClass.new(current_license_key, logger, context).main(args)
# and depend on platform globals + models (GenericObject, GenericEvent,
# GenericObjectsCache, context.eval_function, MongoDB). Loading the file as-is
# would execute it immediately against dependencies that don't exist locally.
# The driver gives you control: stub what the function touches, then hand the
# tester a clean callable.

require_relative "../stubs/mint_platform"

