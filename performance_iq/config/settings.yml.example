elasticsearch:
  host:  https://elasticsearch-dfx.datonis.io
  api_key: "<ES_API_KEY>"
  index: dfx-mongodb-logs-*

prometheus:
  host: https://prometheus.datonis.io   # node_exporter + mongodb_exporter metrics for the digest
  # auth_token: ""                        # optional Bearer token; omit if the endpoint is open
  range_hours: 24                         # VM health = peak/avg over this trailing window
  step: 10m                               # subquery resolution for peak/avg

error_scan:                               # scan other ELK log streams for error-level entries
  lookback_hours: 24
  severity_terms: "error crit alert emerg fatal exception"
  indices:
    - factory-nginx-error-logs*
    - appregistry-nginx-error-logs*
    - appcenter*error*
    - beta-factory-error-logs*

semaphore_scan:                           # machines CONTINUOUSLY stuck on a semaphore lock (sidekiq)
  lookback_hours: 24                      # only the last 24h (current state, not history)
  min_tries: 4                            # this many CONSECUTIVE failures with no lock/unlock since
  index: factory-sidekiq-*

thresholds:
  lookback_hours:   24
  min_duration_ms:  100
  critical_duration_ms: 10000
  high_duration_ms: 1000
  top_n: 20
  rca_limit: 5        # how many HIGH/CRITICAL findings to send to Claude for AI analysis

anthropic:
  api_key: "<ANTHROPIC_API_KEY>"
  model:   claude-sonnet-4-6

rca:
  # Codebase manifests built by bin/extract_manifests.rb (PHASE 1, deterministic).
  # Used to inject existing-index + candidate-pipeline context into the RCA prompt.
  # Defaults to ./manifests relative to lib/ if omitted.
  manifests_dir: manifests

notifications:
  sendgrid_api_key: "<SENDGRID_API_KEY>"
  from_email: datonis@altizon.com
  to_emails:
    - app_dev@altizon.com
  slack_webhook_url: "<SLACK_WEBHOOK_URL>"

github:
  access_token:      "<GITHUB_PAT>"
  factory_repo:      Altizon/factory
  mint_content_repo: Altizon/mint-content   # pipeline fix PRs go here
  base_branch:       master                 # base branch for PRs (master or main)
